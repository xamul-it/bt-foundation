#!/usr/bin/env python3
"""
helpme - Script index and inline help for strategy tool folders.

Default target directory: bin (relative to this script).
"""

from __future__ import annotations

import ast
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path
from textwrap import dedent

HELP_FLAGS = {"-h", "--help"}


@dataclass
class ScriptInfo:
    name: str
    filename: str
    path: Path
    lang: str
    short: str
    long: str


def extract_docstring(path: Path) -> tuple[str, str]:
    try:
        content = path.read_text(encoding="utf-8")
        tree = ast.parse(content)
        doc = ast.get_docstring(tree) or ""
    except Exception:
        doc = ""

    cleaned = dedent(doc).strip()
    if not cleaned:
        return "No description available.", ""

    short = "No description available."
    for line in cleaned.splitlines():
        line = line.strip()
        if line:
            short = line
            break

    return short, cleaned


def extract_shell_comments(path: Path) -> tuple[str, str]:
    try:
        lines = path.read_text(encoding="utf-8").splitlines()
    except Exception:
        return "No description available.", ""

    comments: list[str] = []
    for line in lines:
        stripped = line.strip()
        if not stripped:
            if comments:
                break
            continue
        if stripped.startswith("#!"):
            continue
        if stripped.startswith("#"):
            comments.append(stripped[1:].strip())
            continue
        if comments:
            break
        break

    cleaned = "\n".join(x for x in comments if x).strip()
    if not cleaned:
        return "No description available.", ""

    short = next((x for x in cleaned.splitlines() if x.strip()), "No description available.").strip()
    return short, cleaned


def load_scripts(target_dir: Path) -> list[ScriptInfo]:
    scripts: list[ScriptInfo] = []
    for path in sorted(target_dir.iterdir()):
        if not path.is_file():
            continue
        if path.suffix == ".py":
            short, long = extract_docstring(path)
            scripts.append(
                ScriptInfo(name=path.stem, filename=path.name, path=path, lang="py", short=short, long=long)
            )
        elif path.suffix == ".sh":
            short, long = extract_shell_comments(path)
            scripts.append(
                ScriptInfo(name=path.stem, filename=path.name, path=path, lang="sh", short=short, long=long)
            )
    return scripts


def print_usage() -> None:
    print(
        "Usage:\n"
        "  helpme                               List scripts (default: bin)\n"
        "  helpme <dir>                         List scripts in directory\n"
        "  helpme <command|file>                Show short details\n"
        "  helpme <dir> <command|file>          Show short details in directory\n"
        "  helpme --help <command|file>         Show extended help\n"
        "  helpme <dir> --help <command|file>   Show extended help in directory\n"
        "  helpme --dir <path> ...              Alternate directory syntax\n"
    )


def print_table(scripts: list[ScriptInfo], target_dir: Path) -> None:
    print(f"Directory: {target_dir}")
    print(f"Found {len(scripts)} script files (.py/.sh)\n")

    if not scripts:
        return

    width = max(len(s.filename) for s in scripts)
    print(f"{'COMMAND'.ljust(width)}  DESCRIPTION")
    print(f"{'-' * width}  -----------")
    for s in scripts:
        print(f"{s.filename.ljust(width)}  {s.short}")
    print("\nRun `helpme --help <command>` for extended details.")


def resolve_command(command: str, scripts: list[ScriptInfo]) -> ScriptInfo | None:
    normalized = command.strip()
    for s in scripts:
        if normalized in {s.name, s.filename, str(s.path), s.path.name}:
            return s
    cmd_path = Path(normalized)
    if cmd_path.suffix in {".py", ".sh"}:
        stem = cmd_path.stem
        for s in scripts:
            if s.name == stem:
                return s
    return None


def run_native_help(script: ScriptInfo) -> str | None:
    cmd = [str(script.path), "--help"] if script.lang == "sh" else [sys.executable, str(script.path), "--help"]
    try:
        proc = subprocess.run(
            cmd,
            check=False,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            timeout=6,
        )
    except Exception:
        return None

    output = (proc.stdout or "").strip()
    if proc.returncode == 0 and output:
        return output
    return None


def print_script_help(script: ScriptInfo, extended: bool) -> None:
    print(f"Command: {script.name}")
    print(f"File:    {script.path}")
    print(f"Summary: {script.short}")

    if not extended:
        print("\nUse `helpme --help {}` for full documentation.".format(script.name))
        return

    print("\nExtended help")
    print("-------------")
    if script.long:
        print(script.long)
    else:
        print("No inline documentation found.")

    native = run_native_help(script)
    if native:
        print("\nNative --help")
        print("-------------")
        print(native)
    else:
        print("\nNative --help unavailable in current environment; shown docstring-based help.")


def parse_args(argv: list[str]) -> tuple[Path, str | None, bool]:
    script_dir = Path(__file__).resolve().parent
    target_dir = script_dir

    command: str | None = None
    extended = False

    i = 0
    while i < len(argv):
        arg = argv[i]
        if arg == "--dir":
            if i + 1 >= len(argv):
                raise SystemExit("Missing value for --dir")
            target_dir = Path(argv[i + 1]).expanduser().resolve()
            i += 2
            continue
        if arg in HELP_FLAGS:
            extended = True
            i += 1
            continue
        candidate_dir = Path(arg).expanduser().resolve()
        if command is None and candidate_dir.exists() and candidate_dir.is_dir():
            target_dir = candidate_dir
            i += 1
            continue
        # Se viene passato un path file (es: ./bin/audit_report.py),
        # usa automaticamente la sua directory come base.
        candidate_file = Path(arg).expanduser().resolve()
        if (
            command is None
            and candidate_file.suffix in {".py", ".sh"}
            and candidate_file.exists()
            and candidate_file.is_file()
        ):
            target_dir = candidate_file.parent
            command = candidate_file.name
            i += 1
            continue
        if command is None:
            command = arg
            i += 1
            continue
        raise SystemExit(f"Unexpected argument: {arg}")

    return target_dir, command, extended


def main(argv: list[str]) -> int:
    if argv == ["-h"] or argv == ["--help"]:
        print_usage()
        return 0

    try:
        target_dir, command, extended = parse_args(argv)
    except SystemExit as exc:
        print(exc, file=sys.stderr)
        print_usage()
        return 2

    if not target_dir.exists():
        print(f"Directory not found: {target_dir}", file=sys.stderr)
        return 1

    scripts = load_scripts(target_dir)

    if command is None:
        print_table(scripts, target_dir)
        return 0

    script = resolve_command(command, scripts)
    if script is None:
        print(f"Unknown command: {command}", file=sys.stderr)
        print_table(scripts, target_dir)
        return 1

    print_script_help(script, extended)
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
